POSTGRES_DB=apiwatch
POSTGRES_USER=apiwatch
POSTGRES_PASSWORD=apiwatch
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/apiwatch
SPRING_DATASOURCE_USERNAME=apiwatch
SPRING_DATASOURCE_PASSWORD=apiwatch
APIWATCH_SCHEDULER_ENABLED=true
APIWATCH_SCHEDULER_INTERVAL_MS=5000
APIWATCH_SCHEDULER_INITIAL_DELAY_MS=15000
APIWATCH_FRONTEND_ORIGIN=http://localhost:5173
# Replace this development key with a Base64-encoded 32-byte key in production.
APIWATCH_ENCRYPTION_KEY=YXBpd2F0Y2gtZGV2LWVuY3J5cHRpb24ta2V5LTMyYiE=
APIWATCH_ADMIN_USERNAME=admin
APIWATCH_ADMIN_PASSWORD=replace-admin-password
APIWATCH_VIEWER_USERNAME=viewer
APIWATCH_VIEWER_PASSWORD=replace-viewer-password
APIWATCH_BLOCK_PRIVATE_TARGETS=true
APIWATCH_PRIVATE_TARGET_ALLOWLIST=backend
APIWATCH_DEMO_DATA_ENABLED=true
APIWATCH_DEMO_BASE_URL=http://backend:8080
VITE_API_BASE_URL=http://localhost:8080/api
VITE_DEMO_MODE=false
